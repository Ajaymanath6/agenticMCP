{
  "name": "agentic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,helper -c blue,green \"vite\" \"node server/publish-helper.mjs\"",
    "dev:with-llm": "concurrently -k -n vite,helper,llm -c blue,green,magenta \"vite\" \"node server/publish-helper.mjs\" \"bash './LLM agent/run.sh'\"",
    "dev:vite": "vite",
    "dev:helper": "node server/publish-helper.mjs",
    "dev:vertex-llm": "bash './LLM agent/run.sh'",
    "dev:all": "npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "catalog:prune-canvas": "node scripts/prune-canvas-catalog.mjs",
    "mcp:catalog": "node mcp-server/dist/src/index.js"
  },
  "dependencies": {
    "@remixicon/react": "^4.9.0",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "express": "^5.2.1",
    "html-to-image": "^1.11.13",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
