{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "functions": {
    "api/mcp.ts": {
      "includeFiles": [
        "mcp-server/catalog-data/**",
        "public/blueprints/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    }
  ]
}
